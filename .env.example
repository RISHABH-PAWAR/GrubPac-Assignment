NODE_ENV=development
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Option A: PaaS / Render (DATABASE_URL takes priority over individual vars)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Option B: Local development
DB_HOST=localhost
DB_PORT=5432
DB_NAME=content_broadcasting
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SSL=false
DB_POOL_MAX=20
DB_POOL_IDLE=10000
DB_POOL_ACQUIRE=30000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be minimum 32 characters. Use a strong random value in production.
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_here
JWT_EXPIRES_IN=24h

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
BASE_URL=http://localhost:3000

# ── Redis (optional — server starts and runs fully without Redis) ─────────────
# Option A: PaaS / Render
# REDIS_URL=redis://default:password@host:6379

# Option B: Local
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=60

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
