NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=content_broadcasting
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_POOL_MAX=20
DB_POOL_IDLE=10000
DB_POOL_ACQUIRE=30000

# JWT — must be minimum 32 characters
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_here
JWT_EXPIRES_IN=24h

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
BASE_URL=http://localhost:3000

# Redis (optional — server starts without it)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=60

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
