{
  "name": "content-broadcasting-system",
  "version": "1.0.0",
  "description": "Content Broadcasting System — Backend API for educational content distribution",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/migrations/migrate.js && node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/migrations/migrate.js",
    "seed": "node src/migrations/seed.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "helmet": "8.0.0",
    "ioredis": "5.4.2",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "pg": "8.13.3",
    "uuid": "11.1.0",
    "winston": "3.17.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "nodemon": "3.1.9",
    "supertest": "7.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov"]
  }
}
